# GlamMatch Environment Variables
# NEVER commit .env to GitHub

# Flask secret key — used for JWT token signing (use any long random string)
SECRET_KEY=your_secret_key_here_eg_glammatch_2024_xyz

# Flask environment: development or production
FLASK_ENV=development

# Port the Flask server runs on
FLASK_PORT=5000

# Path to the SQLite database file
DB_PATH=glammatch.db

# Optional: Set to true to enable debug mode
FLASK_DEBUG=true
