# GlamMatch Environment Variables
# Copy this file to .env if you want to manage values locally.
# NEVER commit .env to GitHub.

# Flask environment: development or production
FLASK_ENV=development

# Port the Flask server runs on
FLASK_PORT=5000

# Optional admin portal code.
# Default in app.py is 12345678 if this is not set.
GLAMMATCH_ADMIN_CODE=12345678

# Optional database path note.
# The current app.py uses Backend/glammatch.db by default.
DB_PATH=glammatch.db

# Optional debug mode flag for your own run scripts.
FLASK_DEBUG=true
